# MariaDB custom config - Laravel Docker
# Tuned for large PHP/MySQL applications (big packets, imports, long queries)

[mysqld]
socket = /run/mysqld/mysqld.sock
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
max_connections = 200

# Packet and network (fix Error 1153: packet bigger than max_allowed_packet)
max_allowed_packet = 128M
net_read_timeout = 120
net_write_timeout = 120

# Session timeouts (long-running scripts / imports)
wait_timeout = 600
interactive_timeout = 600

# InnoDB (larger buffer for big tables / joins)
innodb_buffer_pool_size = 512M
# If MariaDB won't start after increasing this, stop container, remove storage/mysql/ib_logfile0 & ib_logfile1, then start again
innodb_log_file_size = 128M
innodb_log_buffer_size = 16M
innodb_flush_log_at_trx_commit = 2

# Query / temp tables (large result sets, bulk ops)
tmp_table_size = 128M
max_heap_table_size = 128M
join_buffer_size = 4M
sort_buffer_size = 4M
read_buffer_size = 2M
read_rnd_buffer_size = 4M

[client]
socket = /run/mysqld/mysqld.sock
default-character-set = utf8mb4
max_allowed_packet = 128M

[mysql]
socket = /run/mysqld/mysqld.sock
default-character-set = utf8mb4
max_allowed_packet = 128M
