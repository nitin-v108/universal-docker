# Consistent line endings across platforms
# LF for text files (Unix-style)
* text=auto eol=lf

# Explicit binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Shell scripts
*.sh text eol=lf
*.conf text eol=lf
*.yml text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
