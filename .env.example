# ============================================
# Docker Laravel Environment
# Copy to .env and adjust for your setup
# ============================================

# ============================================
# MySQL / MariaDB
# ============================================
# Root user for administrative tasks (e.g. create databases)
# WARNING: Change in production; use a strong password
MYSQL_ROOT_PASSWORD=root

# Laravel/default app user
# Must match DB_USERNAME/DB_PASSWORD in each Laravel project .env
MYSQL_USER=laravel
MYSQL_PASSWORD=secret

# ============================================
# Redis
# ============================================
# Shared by Laravel (cache, session, queue) and Credit Control API
# Use same value in Laravel REDIS_PASSWORD and Credit Control REDIS_URL
# WARNING: Change in production
REDIS_PASSWORD=root

# ============================================
# MongoDB
# ============================================
# Root user for init
# WARNING: Change in production; use a strong password
MONGO_ROOT_PASSWORD=root

# Credit Control API user (created by docker/mongodb/init; used in MONGO_DB_BASE_URI)
# Required: set a secure password; must match in credit-control and init scripts
MONGO_CC_ADMIN_USER=ccDevAdm
MONGO_CC_ADMIN_PASSWORD=changeme

# ============================================
# Application
# ============================================
APP_ENV=local

# ============================================
# Xdebug
# ============================================
# Set to 'debug' or 'develop' to enable; 'off' for better performance
XDEBUG_MODE=off
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_START_WITH_REQUEST=no
